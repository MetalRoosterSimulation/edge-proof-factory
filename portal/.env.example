# Copy to .env.local for local dev, or set as Vercel project env vars for
# preview/production. Both values are public (anon key, protected by RLS —
# see supabase/migrations/0001_init.sql) and safe in a browser bundle, but
# .env.local should still stay untracked (it is, via .gitignore).

# Local Supabase (from `npm run db:start`, then `supabase status`):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Hosted Supabase project (Project Settings -> API):
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI stand-in tier (/api/explain, /api/chat) — hosted analog of the kit's
# on-prem SUSE AI tier. Optional: without it the routes degrade gracefully
# and the demo falls back to the deterministic signature diagnosis.
# Set the same variable on the Vercel project (Production + Preview).
ANTHROPIC_API_KEY=
# Optional model override (default claude-opus-4-8)
ANTHROPIC_MODEL=
