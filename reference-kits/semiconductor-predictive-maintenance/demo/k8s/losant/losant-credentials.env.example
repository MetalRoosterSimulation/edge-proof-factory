# Copy to losant-credentials.env and fill in. That file is gitignored.
# Get these from the Losant platform:
#   1. Create (or open) a Losant Application.
#   2. Devices -> add a device (type: Standalone) -> copy its Device ID.
#   3. Security -> Application Tokens / Access Keys -> create -> copy key+secret.
LOSANT_DEVICE_ID=
LOSANT_ACCESS_KEY=
LOSANT_ACCESS_SECRET=
